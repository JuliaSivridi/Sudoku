<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon foreground: adds safe-zone padding around the image.
     Android clips the outer ~17% (~18dp out of 108dp) depending on launcher shape.
     Padding of 20dp keeps the full grid visible inside any clipping mask. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:drawable="@drawable/ic_launcher_custom"
        android:top="20dp"
        android:bottom="20dp"
        android:left="20dp"
        android:right="20dp" />
</layer-list>
